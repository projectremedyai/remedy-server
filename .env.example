# Remedy Server HTTP backend — example environment.
# Copy to `.env` and edit before running docker compose in production.

# ---- Docker/Caddy ----------------------------------------------------------
# Public API hostname and optional Caddy global options for docker-compose.
DOMAIN=localhost
# Example for Let's Encrypt contact email:
# CADDY_GLOBAL_OPTIONS=email ops@example.com
CADDY_GLOBAL_OPTIONS=

# ---- Runtime mode ----------------------------------------------------------
# Local dev can stay "development". docker-compose overrides this to
# "production" and the app will fail fast unless APP_API_KEY is set and CORS
# uses explicit origins.
APP_ENV=development
APP_DOCS_ENABLED=true

# ---- Auth ------------------------------------------------------------------
# If empty, auth is disabled (dev mode). Otherwise every /v1/* request must
# send X-API-Key: <this value>.
APP_API_KEY=

# ---- Ollama Cloud ----------------------------------------------------------
# Required in docker-compose / production. For a local Ollama-compatible
# endpoint, override OLLAMA_BASE_URL and use an appropriate local model.
OLLAMA_BASE_URL=https://ollama.com/v1
OLLAMA_API_KEY=
OLLAMA_MODEL=kimi-k2.7-code:cloud
OLLAMA_VISION_MODEL=kimi-k2.7-code:cloud
OLLAMA_ESCALATION_MODEL=kimi-k2.7-code:cloud
# Quality judges must use a different model family from the remediation models.
QUALITY_JUDGE_BACKEND=ollama
QUALITY_JUDGE_BASE_URL=
QUALITY_JUDGE_MODEL=mistral-large-3:675b
# Behavioral proxy answerers should also differ from the artifact generator.
BEHAVIORAL_TEST_BACKEND=ollama
BEHAVIORAL_TEST_MODEL=gemma4:31b-cloud
# Optional JSON cache for behavioral proxy results, keyed by document hash.
BEHAVIORAL_TEST_CACHE_PATH=
QUALITY_EXPERIMENT_STORE_PATH=./quality_experiments.db
QUALITY_REVIEW_QUEUE_PATH=./quality_review_queue.jsonl
QUALITY_REVIEW_SUBMISSION_PATH=./quality_review_submissions.jsonl
QUALITY_CORPUS_ROOT_PATH=./tools/corpus_annotations/v1
# Blocks opt-in quality execution unless calibration rows meet the threshold.
# Defaults to true in production when unset.
QUALITY_REQUIRE_CALIBRATION=false
QUALITY_MIN_COHENS_KAPPA=0.8
QUALITY_MIN_CALIBRATION_SAMPLES=1
# 0 disables age checks; set a positive value to require fresh calibration rows.
QUALITY_MAX_CALIBRATION_AGE_DAYS=0
# Optional comma-separated reviewer keys for /v1/quality/review/* endpoints.
APP_REVIEWER_KEYS=
# Optional dedicated vision endpoint. For example, keep text on Ollama Cloud
# while routing vision to local Ollama with VISION_BASE_URL=http://localhost:11434
VISION_BASE_URL=
# Optional fallback chain for vision calls. Root local Ollama URLs use
# Ollama's native /api/chat surface; /v1 URLs use OpenAI-compatible chat.
OLLAMA_VISION_FALLBACK_MODELS=
OLLAMA_VISION_FALLBACK_BASE_URLS=
# Optional task router for OpenAI-compatible served LoRAs. Leave blank unless
# task-specific adapters are available behind VISION_BASE_URL or per-task URLs.
OLLAMA_VISION_TASK_MODELS=
OLLAMA_VISION_TASK_BASE_URLS=
OLLAMA_VISION_ROUTER_ALLOW_FALLBACK=0

# ---- Uploads ---------------------------------------------------------------
# Max upload size in megabytes. Requests above this return 413.
MAX_UPLOAD_MB=50

# ---- Storage ---------------------------------------------------------------
# SQLite file holding job metadata.
JOB_STORE_PATH=./jobs.db
# Per-job working directory (inputs, outputs, reports).
JOB_DIR=./job_data
# Engine output/log directories used by rebuild and extraction internals.
OUTPUT_DIR=./output
LOG_DIR=./logs
# How long to keep completed jobs before pruning.
JOB_RETENTION_HOURS=24
# Interval between retention pruner ticks, in hours.
PRUNE_INTERVAL_HOURS=1

# ---- JobStore backups ------------------------------------------------------
# Periodic online SQLite backups of JOB_STORE_PATH — safe with the worker
# running. Timestamped files are written into JOB_BACKUP_DIR and the oldest
# are pruned once the count exceeds JOB_BACKUP_KEEP_N.
# Directory for timestamped backup files (jobs_YYYYMMDD_HHMMSSZ.db).
JOB_BACKUP_DIR=./job_backups
# Number of backup files to retain (oldest beyond this are deleted).
JOB_BACKUP_KEEP_N=24
# Interval between backup ticks, in hours (1 => roughly hourly).
JOB_BACKUP_INTERVAL_HOURS=1

# ---- Queue -----------------------------------------------------------------
# Worker concurrency (single-process).
WORKER_CONCURRENCY=1

# ---- External validators ---------------------------------------------------
# Optional local overrides. The Docker runtime sets these to bundled binaries.
# VERAPDF_PATH=/usr/local/bin/verapdf
# EPUBCHECK_PATH=/usr/local/bin/epubcheck
# ACE_PATH=/opt/node/bin/ace

# ---- CORS ------------------------------------------------------------------
# Comma-separated origins. Use explicit origins in production; "*" is rejected
# when APP_ENV=production.
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
